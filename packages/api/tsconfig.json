{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": "../../",
    "paths": {
      "@repo/api/*": ["packages/api/src/*"],
      "@repo/db/*": ["packages/db/*"],
      "@repo/web/*": ["apps/web/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}